# LittleHelpers – miljövariabler för Docker Compose
# Kopiera till .env och fyll i dina värden.
# Filen .env ska ALDRIG committas till git.

# ── PostgreSQL ────────────────────────────────────────────────────
# Välj ett starkt lösenord
POSTGRES_PASSWORD=CHANGE_ME

# ── JWT ───────────────────────────────────────────────────────────
# Minst 32 slumpmässiga tecken, t.ex.: openssl rand -base64 48
JWT_KEY=CHANGE_ME_USE_A_LONG_RANDOM_SECRET_KEY_MIN_32_CHARS
JWT_ISSUER=littlehelpers
JWT_AUDIENCE=littlehelpers
# Tokenlivslängd i timmar
JWT_ACCESS_TOKEN_LIFETIME_HOURS=168
JWT_RENEW_TOKEN_LIFETIME_HOURS=336

# ── Seed-konto ────────────────────────────────────────────────────
# Lösenord för det initiala admin-kontot (skapas vid första start)
SEED_ADMIN_PASSWORD=CHANGE_ME

# ── Månadscykel (valfritt) ────────────────────────────────────────
# Dag i månaden då ny månadscykel börjar (1-31). Exempel: 31
MONTHLY_CYCLE_BREAKPOINT_DAY=1

# ── Firebase-notiser (valfritt) ───────────────────────────────────
FIREBASE_NOTIFICATIONS_ACTIVE=false
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
# Behåll \n i värdet om du använder env-fil.
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=

# ── Docker-images (valfritt – används om du pusha till ett register) ──
# APISERVICE_IMAGE=ghcr.io/yourorg/littlehelpers-api:latest
# WEBFRONTEND_IMAGE=ghcr.io/yourorg/littlehelpers-web:latest

# ── Port ──────────────────────────────────────────────────────────
# Vilken port frontend exponeras på värddatorn (default: 80)
WEB_PORT=80

# ── Web app metadata (valfritt) ──────────────────────────────────
# Visningsnamn och metadata för installerbar web app + HTML-title.
WEBAPP_NAME=LittleHelpers
WEBAPP_SHORT_NAME=LittleHelpers
WEBAPP_DESCRIPTION=Family chore management app.
WEBAPP_LANG=en
WEBAPP_TITLE=LittleHelpers
