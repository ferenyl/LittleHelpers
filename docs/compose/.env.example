# LittleHelpers – miljövariabler för Docker Compose
# Kopiera till .env och fyll i dina värden.
# Filen .env ska ALDRIG committas till git.

# ── PostgreSQL ────────────────────────────────────────────────────
# Välj ett starkt lösenord
POSTGRES_PASSWORD=CHANGE_ME

# ── JWT ───────────────────────────────────────────────────────────
# Minst 32 slumpmässiga tecken, t.ex.: openssl rand -base64 48
JWT_KEY=CHANGE_ME_USE_A_LONG_RANDOM_SECRET_KEY_MIN_32_CHARS
JWT_ISSUER=littlehelpers
JWT_AUDIENCE=littlehelpers

# ── Seed-konto ────────────────────────────────────────────────────
# Lösenord för det initiala admin-kontot (skapas vid första start)
SEED_ADMIN_PASSWORD=CHANGE_ME

# ── Docker-images (valfritt – används om du pusha till ett register) ──
# APISERVICE_IMAGE=ghcr.io/yourorg/littlehelpers-api:latest
# WEBFRONTEND_IMAGE=ghcr.io/yourorg/littlehelpers-web:latest

# ── Port ──────────────────────────────────────────────────────────
# Vilken port frontend exponeras på värddatorn (default: 80)
WEB_PORT=80
